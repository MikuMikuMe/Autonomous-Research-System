# Copy to .env and fill in your keys. Do NOT commit .env.

# ── LLM Providers (at least one required) ──
# GOOGLE_API_KEY=your-gemini-api-key-from-aistudio-google-com
# GEMINI_MODEL=gemini-2.5-flash

# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o

# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# LLM_PROVIDER=google  # google | openai | anthropic | ollama

# ── Web Search ──
# TAVILY_API_KEY=your-tavily-api-key

# ── Research (optional) ──
# ALPHAXIV_TOKEN=your-alphaxiv-token-for-research-pipeline
# ALPHAXIV_ASSISTANT_URL=https://api.alphaxiv.org/assistant/v2/chat

# ── Distributed Tracing (optional) ──
# LANGCHAIN_API_KEY=your-langsmith-api-key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=autonomous-research

# ── Telegram Bot (optional) ──
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
