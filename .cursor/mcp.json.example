{
  "mcpServers": {
    "alphaxiv": {
      "url": "https://api.alphaxiv.org/mcp/v1",
      "headers": {
        "Authorization": "Bearer YOUR_ALPHAXIV_TOKEN"
      }
    },
    "arxiv-mcp-server": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "arxiv-mcp-server",
        "--storage-path",
        "outputs/arxiv_papers"
      ]
    }
  }
}
